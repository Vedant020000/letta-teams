{
  "name": "letta-teams-sdk",
  "version": "0.10.0",
  "description": "Reusable SDK for orchestrating teams of stateful Letta agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./daemon": {
      "types": "./dist/daemon.d.ts",
      "import": "./dist/daemon.js"
    },
    "./ipc": {
      "types": "./dist/ipc.d.ts",
      "import": "./dist/ipc.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./targets": {
      "types": "./dist/targets.d.ts",
      "import": "./dist/targets.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./task-visibility": {
      "types": "./dist/task-visibility.d.ts",
      "import": "./dist/task-visibility.js"
    },
    "./council/store": {
      "types": "./dist/council/store.d.ts",
      "import": "./dist/council/store.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Vedant Sondur <vedantsondur020@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vedant020000/letta-teams.git",
    "directory": "packages/letta-teams-sdk"
  },
  "bugs": {
    "url": "https://github.com/Vedant020000/letta-teams/issues"
  },
  "homepage": "https://github.com/Vedant020000/letta-teams/tree/main/packages/letta-teams-sdk",
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "dependencies": {
    "@letta-ai/letta": "^0.0.1",
    "@letta-ai/letta-client": "^1.7.11",
    "@letta-ai/letta-code-sdk": "^0.1.10",
    "p-limit": "^6.2.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      [
        "@semantic-release/release-notes-generator",
        {
          "writerOpts": {
            "groupBy": "type",
            "commitGroupsSort": [
              "feat",
              "fix",
              "perf",
              "refactor"
            ],
            "commitsSort": "scope"
          }
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md",
          "changelogTitle": "# Changelog"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/github",
        {
          "assets": []
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
