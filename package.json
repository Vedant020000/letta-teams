{
  "name": "letta-teams-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w letta-teams-sdk && npm run build -w letta-teams",
    "dev": "npm run dev -w letta-teams",
    "start": "npm run start -w letta-teams",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint -w letta-teams-sdk && npm run build -w letta-teams-sdk && npm run lint -w letta-teams",
    "release": "multi-semantic-release --sequential-init",
    "release:dry-run": "multi-semantic-release --sequential-init --dry-run --no-ci"
  },
  "multi-release": {
    "sequentialInit": true,
    "deps": {
      "bump": "override",
      "release": "patch",
      "prefix": ""
    }
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.2.0",
    "multi-semantic-release": "^3.1.0",
    "proper-lockfile": "^4.1.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
